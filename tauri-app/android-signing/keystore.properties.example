# Release signing for personal Android builds.
#
# Copy this file to:
#   src-tauri/gen/android/keystore.properties
# and fill in the values. That destination is gitignored — never commit it,
# and never commit the .jks/.keystore file it points to.
#
# storeFile must be an absolute path to the keystore created with keytool
# (see README.md). Keep the keystore and these passwords backed up: losing
# them means you can no longer ship updates that overwrite the installed app.

storeFile=/absolute/path/to/magical-merchant.jks
storePassword=
keyAlias=magical-merchant
keyPassword=
