{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-app-schemas/refs/heads/main/tauri/capability.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "deep-link:default",
    "geolocation:allow-check-permissions",
    "geolocation:allow-request-permissions",
    "geolocation:allow-get-current-position"
  ]
}
