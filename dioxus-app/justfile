[private]
default:
  @just --list

fmt:
  cargo fmt --all

check:
  cargo check --all-targets
  cargo clippy --all-targets -- -D warnings

test:
  cargo test --all-targets

verify: fmt check test

dev:
  RUST_LOG=warn,magical_merchant_dioxus=debug dx serve --platform desktop

build:
  dx build --platform desktop --release

clean:
  cargo clean
